{
  "project_name": "Room Temperature Comfort (Non-Monotonic)",
  "description": "This project demonstrates the use of the UTANM algorithm to model non-monotonic preferences for room temperature comfort. The criteria include various factors that influence comfort, and the alternatives represent different temperature settings with their associated attributes.",
  "algorithm_settings": {
    "algorithm": "UTANM",
    "sigma": 0.05,
    "breakpoints": "uniform",
    "theta": 0.0,
    "big_m": 1000.0,
    "ineq": 0.001,
    "max_nonmonotonicity_degree": 5,
    "objective_threshold": 0.0,
    "minimum_improvement": 0.0,
    "missing_value_treatment": "assumeAverageValue"
  },
  "criteria": {
    "Room temperature (°C)": {
      "type": "cardinal",
      "shape": "gain",
      "n_segments": 5
    }
  },
  "alternatives": {
